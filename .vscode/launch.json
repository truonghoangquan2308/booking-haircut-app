{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "flutter_booking_app",
            "cwd": "flutter_booking_app",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "flutter_booking_app (Android Emulator API)",
            "cwd": "flutter_booking_app",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define",
                "API_BASE_URL=http://10.0.2.2:3000"
            ]
        },
        // Real Android device: replace the IP below with your computer's LAN address on the same network.
        {
            "name": "flutter_booking_app (Real Device - LAN API)",
            "cwd": "flutter_booking_app",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define",
                "API_BASE_URL=http://192.168.1.6:3000"
            ]
        },
        {
            "name": "flutter_booking_app (profile mode)",
            "cwd": "flutter_booking_app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "flutter_booking_app (release mode)",
            "cwd": "flutter_booking_app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}